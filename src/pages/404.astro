---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="404 — Page Not Found | ICRA Contractor Domain"
  noindex={true}
>
  <div class="min-h-screen flex items-center justify-center px-4 bg-slate-50">
    <div class="text-center">
      <div class="text-8xl sm:text-9xl font-extrabold tracking-tighter bg-gradient-to-br from-icra-teal to-icra-teal-bright bg-clip-text text-transparent mb-6">
        404
      </div>
      <h1 class="text-2xl sm:text-3xl font-semibold text-slate-900 mb-4">Page Not Found</h1>
      <p class="text-slate-500 max-w-md mx-auto mb-10 text-sm sm:text-base leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
        Explore the opportunity to own the definitive domain for ICRA-specialized healthcare construction contractors.
      </p>
      <a href="/"
         class="inline-flex items-center gap-2 px-8 py-3 rounded-full border border-icra-teal/40 hover:bg-icra-teal hover:text-white text-icra-teal font-semibold text-sm transition-all duration-300">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Return Home
      </a>
    </div>
  </div>
</MainLayout>

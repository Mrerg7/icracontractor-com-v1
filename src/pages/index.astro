---
import MainLayout from '../layouts/MainLayout.astro';

const contactEmail = "sales@desertrich.com";
const subjectLine = "Acquisition Inquiry — icracontractor.com";
const mailtoLink = `mailto:${contactEmail}?subject=${encodeURIComponent(subjectLine)}`;

const marketStats = [
  { value: "$30B+", label: "Annual U.S. hospital & clinic construction spend", detail: "Ongoing capital projects and renovations create steady demand for contractors who can safely work in active patient care environments.", icon: "hospital" },
  { value: "Competitive Edge", label: "ICRA capability wins more bids", detail: "Contractors who can credibly demonstrate ICRA expertise are increasingly favored during pre-qualification and bid evaluation processes.", icon: "trophy" },
  { value: "Premium Positioning", label: "Specialized contractors command better margins", detail: "Projects requiring sophisticated infection control protocols often carry higher margins and lead to longer-term relationships with health systems and GCs.", icon: "chart" },
];

const brandPillars = [
  { title: "Field-Proven Execution", desc: "Real-world experience delivering complex healthcare projects while maintaining strict infection control — from barrier installation to negative air management and daily compliance monitoring.", icon: "hardhat" },
  { title: "Class I–IV Protocol Expertise", desc: "Deep understanding of ICRA classifications, proper containment strategies, pressure differentials, HEPA filtration, and the practical realities of maintaining protocols on active job sites.", icon: "shield" },
  { title: "Trusted by Hospitals & GCs", desc: "The name signals to health systems and general contractors that you are a reliable partner who understands both construction and the critical importance of protecting patients.", icon: "handshake" },
  { title: "Trained & Disciplined Crews", desc: "A workforce that doesn't just follow ICRA procedures — they understand why they matter. Daily checklists, pressure monitoring, and immediate response protocols become second nature.", icon: "users" },
];

const domainValues = [
  { title: "Direct & Descriptive .com", desc: "\"ICRA Contractor\" as a .com is clear, professional, and instantly tells hospitals, architects, and general contractors exactly what you do. It removes any ambiguity from the first interaction.", icon: "check" },
  { title: "Professional Email & Presence", desc: "@icracontractor.com addresses look established on proposals, bids, contracts, and emails. The domain also works beautifully on trucks, job site signage, and marketing materials.", icon: "envelope" },
  { title: "Strong & Memorable", desc: "Clean, easy to say and spell. Performs exceptionally well in verbal introductions, RFPs, pre-qualification documents, and when clients are searching for specialized contractors.", icon: "link" },
  { title: "Excellent Search Alignment", desc: "Strong match for high-intent searches such as \"ICRA contractor\", \"healthcare construction contractor\", \"ICRA builder\", \"infection control contractor\", and related B2B terms.", icon: "search" },
  { title: "Built for Long-Term Value", desc: "Healthcare facilities will always need renovation and expansion work that requires infection control expertise. This brand has permanent relevance in a regulated, high-value niche.", icon: "refresh" },
  { title: "Clear Business Focus", desc: "Ideal foundation for a specialized healthcare construction or renovation company that wants to own the \"ICRA Contractor\" positioning in their market.", icon: "rocket" },
];

const businessModels = [
  { title: "Specialized Healthcare Contractor", desc: "Operate as a dedicated contractor focused on ICRA-compliant work in occupied hospitals, clinics, and medical facilities.", icon: "hardhat" },
  { title: "Occupied-Facility Renovation Specialist", desc: "Focus on complex renovation and fit-out projects that require sophisticated containment and infection control protocols.", icon: "tools" },
  { title: "ICRA-Trained Crew Network", desc: "Build and brand a network of trained crews and specialty trades that operate under the icracontractor.com standard.", icon: "users" },
  { title: "Preferred Subcontractor Partner", desc: "Position the brand as the go-to ICRA specialist that larger general contractors bring onto major hospital projects.", icon: "handshake" },
];

const buyerProfiles = [
  { title: "General Contractors & Specialty Trades", desc: "Launch or rebrand a dedicated healthcare division focused on ICRA-compliant construction and renovation work.", icon: "hardhat" },
  { title: "Medical Renovation Companies", desc: "Differentiate with a name that clearly signals expertise in complex, infection-control-sensitive renovation projects.", icon: "tools" },
  { title: "Subcontractor Networks & Crews", desc: "Build a branded network of trained ICRA crews that larger GCs can confidently bring onto hospital projects.", icon: "users" },
  { title: "Joint Venture & Preferred Partner", desc: "Position the brand as the specialized ICRA contractor partner for larger construction firms bidding on major healthcare work.", icon: "handshake" },
  { title: "Established Construction Companies", desc: "Add a high-margin, specialized healthcare construction arm under a clear and credible brand name.", icon: "building" },
  { title: "Strategic Domain Investors", desc: "Acquire a clean, professional .com domain with clear commercial application in a growing regulated niche.", icon: "globe" },
];
---

<MainLayout>
  <!-- ============================================ -->
  <!-- NAVBAR                                       -->
  <!-- ============================================ -->
  <nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
    <div class="max-w-screen-2xl mx-auto">
      <div class="px-8 py-5 flex items-center justify-between">
        <div class="flex items-center gap-x-3">
          <!-- Logo -->
          <div class="flex items-center gap-x-2.5">
            <div class="w-9 h-9 bg-icra-teal rounded-2xl flex items-center justify-center shadow-inner">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
            </div>
            <div>
              <span class="font-semibold tracking-tighter text-3xl">icra</span>
              <span class="text-icra-teal font-semibold text-xl">contractor.com</span>
            </div>
          </div>
          <div class="premium-badge flex items-center gap-x-1.5 ml-1">
            <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span class="font-semibold tracking-[0.5px] text-[10px]">PREMIUM</span>
          </div>
        </div>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
          <a href="#opportunity" class="text-slate-600 hover:text-slate-900 transition-colors">Opportunity</a>
          <a href="#brand" class="text-slate-600 hover:text-slate-900 transition-colors">The Brand</a>
          <a href="#why-domain" class="text-slate-600 hover:text-slate-900 transition-colors">Why This Domain</a>
          <a href="#acquire" class="text-slate-600 hover:text-slate-900 transition-colors">Acquire</a>
        </div>

        <div class="flex items-center gap-x-3">
          <a href={mailtoLink}
             class="hidden md:block px-5 py-2.5 text-sm font-semibold bg-white border border-slate-300 hover:border-slate-400 text-slate-700 rounded-3xl transition-all active:scale-[0.985]">
            Make an Offer
          </a>
          <a href={mailtoLink}
             class="px-6 py-2.5 text-sm font-semibold bg-icra-teal hover:bg-icra-deep text-white rounded-3xl transition-all active:scale-[0.985] shadow-sm flex items-center gap-x-2">
            <span>Inquire Now</span>
          </a>

          <!-- Mobile menu toggle -->
          <button class="md:hidden w-10 h-10 flex items-center justify-center text-slate-600" id="mobile-menu-btn">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-b border-slate-200 px-6 py-4">
      <div class="flex flex-col gap-y-3 text-sm font-medium">
        <a href="#opportunity" class="py-1.5 text-slate-700">Opportunity</a>
        <a href="#brand" class="py-1.5 text-slate-700">The Brand</a>
        <a href="#why-domain" class="py-1.5 text-slate-700">Why This Domain</a>
        <a href="#acquire" class="py-1.5 text-slate-700">Acquire</a>
        <div class="pt-3 border-t">
          <a href={mailtoLink}
             class="block w-full py-3 text-center text-sm font-semibold bg-icra-teal text-white rounded-3xl">Inquire Now</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- ============================================ -->
  <!-- HERO                                         -->
  <!-- ============================================ -->
  <header class="healthcare-gradient text-white">
    <div class="max-w-screen-2xl mx-auto px-8 pt-16 pb-20 md:pt-20 md:pb-24">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-x-2 bg-white/10 backdrop-blur-md px-4 py-1.5 rounded-3xl mb-6 border border-white/20">
          <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse-slow"></div>
          <span class="text-sm font-medium tracking-wide">EXCLUSIVELY AVAILABLE</span>
        </div>

        <h1 class="text-6xl md:text-7xl leading-[1.05] tracking-tighter font-semibold mb-4">
          icracontractor.com
        </h1>

        <p class="max-w-3xl text-2xl md:text-3xl text-teal-100 tracking-tight mb-3">
          The direct brand for the ICRA Contractor.
        </p>

        <p class="max-w-2xl text-lg text-teal-200/90 mb-9">
          Own the professional .com that instantly identifies your company as the specialized contractor
          who understands and executes Infection Control Risk Assessment on healthcare construction projects.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={mailtoLink}
             class="group inline-flex items-center justify-center gap-x-3 px-8 py-4 bg-white text-teal-700 font-semibold text-lg rounded-3xl hover:bg-teal-50 active:bg-white transition-all shadow-xl shadow-black/10">
            <span>Secure This Domain</span>
            <svg class="w-5 h-5 group-active:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>

          <a href="#opportunity"
             class="inline-flex items-center justify-center gap-x-2 px-7 py-4 border border-white/30 hover:bg-white/10 text-white font-medium rounded-3xl transition-all text-lg">
            <span>Explore the Opportunity</span>
          </a>
        </div>

        <!-- Trust signals -->
        <div class="mt-8 flex items-center gap-x-6 text-sm">
          <div class="flex items-center -space-x-1">
            <div class="w-6 h-6 bg-white/20 rounded-full border border-white/40"></div>
            <div class="w-6 h-6 bg-white/20 rounded-full border border-white/40"></div>
            <div class="w-6 h-6 bg-white/20 rounded-full border border-white/40"></div>
          </div>
          <span class="text-teal-200 text-sm">The name that tells hospitals and GCs you're the ICRA contractor they can trust</span>
        </div>
      </div>
    </div>
  </header>

  <!-- ============================================ -->
  <!-- TRUST / STATS BAR                            -->
  <!-- ============================================ -->
  <div class="border-b border-slate-200 bg-white">
    <div class="max-w-screen-2xl mx-auto px-8 py-5">
      <div class="flex flex-wrap justify-center md:justify-between items-center gap-x-8 gap-y-4 text-center md:text-left">
        <div class="flex items-center gap-x-3">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="font-medium text-sm text-slate-600">Premium .com — professional & established</span>
        </div>
        <div class="flex items-center gap-x-3">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="font-medium text-sm text-slate-600">Hospitals increasingly pre-qualify ICRA-capable contractors</span>
        </div>
        <div class="flex items-center gap-x-3">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="font-medium text-sm text-slate-600">ICRA expertise is now a major competitive advantage on bids</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- THE OPPORTUNITY                              -->
  <!-- ============================================ -->
  <section id="opportunity" class="max-w-screen-2xl mx-auto px-8 pt-16 pb-12">
    <div class="max-w-3xl mb-10">
      <div class="uppercase tracking-[2px] text-icra-teal text-xs font-semibold mb-2">THE MARKET</div>
      <h2 class="text-4xl font-bold tracking-tighter leading-tight">The contractors who truly understand ICRA win the best healthcare projects.</h2>
      <p class="mt-4 text-lg text-slate-600">Healthcare construction and renovation work is increasing across the country. Much of it occurs in occupied facilities with strict infection control requirements. General contractors and health systems are actively seeking subcontractors and specialty contractors who can demonstrate real ICRA capability — not just paperwork compliance. Owning a name that clearly signals this expertise gives you an immediate advantage in bidding and client conversations.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      <div class="bg-white border border-slate-200 rounded-3xl p-7 modern-card">
        <div class="flex justify-between items-start">
          <div>
            <div class="text-5xl font-semibold tracking-tighter text-slate-900">$30B+</div>
            <div class="text-icra-teal font-medium mt-1">Annual U.S. hospital & clinic construction spend</div>
          </div>
          <svg class="w-10 h-10 text-icra-teal-pale" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
        </div>
        <p class="text-sm text-slate-500 mt-5 leading-snug">Ongoing capital projects and renovations create steady demand for contractors who can safely work in active patient care environments.</p>
      </div>

      <div class="bg-white border border-slate-200 rounded-3xl p-7 modern-card">
        <div class="flex justify-between items-start">
          <div>
            <div class="text-5xl font-semibold tracking-tighter text-slate-900">Competitive Edge</div>
            <div class="text-icra-teal font-medium mt-1">ICRA capability wins more bids</div>
          </div>
          <svg class="w-10 h-10 text-icra-teal-pale" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
        </div>
        <p class="text-sm text-slate-500 mt-5 leading-snug">Contractors who can credibly demonstrate ICRA expertise are increasingly favored during pre-qualification and bid evaluation processes.</p>
      </div>

      <div class="bg-white border border-slate-200 rounded-3xl p-7 modern-card">
        <div class="flex justify-between items-start">
          <div>
            <div class="text-5xl font-semibold tracking-tighter text-slate-900">Premium Positioning</div>
            <div class="text-icra-teal font-medium mt-1">Specialized contractors command better margins</div>
          </div>
          <svg class="w-10 h-10 text-icra-teal-pale" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
        </div>
        <p class="text-sm text-slate-500 mt-5 leading-snug">Projects requiring sophisticated infection control protocols often carry higher margins and lead to longer-term relationships with health systems and GCs.</p>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- THE BRAND                                    -->
  <!-- ============================================ -->
  <section id="brand" class="bg-white border-y border-slate-200 py-16">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="max-w-3xl mb-10">
        <div class="uppercase tracking-[2px] text-icra-teal text-xs font-semibold mb-2">THE ICRA CONTRACTOR BRAND</div>
        <h2 class="text-4xl font-bold tracking-tighter leading-tight">What icracontractor.com represents.</h2>
        <p class="mt-4 text-lg text-slate-600">This is the brand for the construction company that positions itself as the go-to ICRA contractor — the one that hospitals and general contractors call when infection control during construction is non-negotiable.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {brandPillars.map((pillar) => (
          <div class="bg-slate-50 border border-slate-100 rounded-3xl p-6 modern-card">
            <div class="w-11 h-11 flex items-center justify-center bg-icra-teal-pale text-icra-teal rounded-2xl mb-5">
              {pillar.icon === 'hardhat' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>}
              {pillar.icon === 'shield' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>}
              {pillar.icon === 'handshake' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>}
              {pillar.icon === 'users' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/></svg>}
            </div>
            <h4 class="font-semibold text-lg tracking-tight mb-2">{pillar.title}</h4>
            <p class="text-sm text-slate-600 leading-relaxed">{pillar.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- WHY THIS DOMAIN                              -->
  <!-- ============================================ -->
  <section id="why-domain" class="max-w-screen-2xl mx-auto px-8 py-16">
    <div class="max-w-3xl mb-9">
      <div class="uppercase tracking-[2px] text-icra-teal text-xs font-semibold mb-2">THE STRATEGIC ASSET</div>
      <h2 class="text-4xl font-bold tracking-tighter leading-tight">Why icracontractor.com is a powerful brand for a construction company.</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {domainValues.map((item) => (
        <div class="value-prop bg-white border border-slate-200 p-7 rounded-3xl modern-card">
          <div class="flex items-center gap-x-3 mb-4">
            <div class="text-icra-teal">
              {item.icon === 'check' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>}
              {item.icon === 'envelope' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>}
              {item.icon === 'link' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>}
              {item.icon === 'search' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>}
              {item.icon === 'refresh' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>}
              {item.icon === 'rocket' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>}
            </div>
            <h4 class="font-semibold text-xl tracking-tight">{item.title}</h4>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================ -->
  <!-- BUSINESS MODELS (dark)                       -->
  <!-- ============================================ -->
  <section class="bg-slate-900 text-white py-16">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="max-w-2xl mb-9">
        <div class="text-teal-400 text-xs tracking-[2px] font-semibold mb-2">BUILD THE CONTRACTOR BRAND</div>
        <h2 class="text-4xl tracking-tighter font-semibold">Practical ways to activate icracontractor.com.</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        {businessModels.map((model) => (
          <div class="bg-white/5 hover:bg-white/10 border border-white/10 p-6 rounded-3xl transition-colors">
            <div class="text-icra-teal-bright mb-4">
              {model.icon === 'hardhat' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>}
